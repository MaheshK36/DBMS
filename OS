#define SharedMemSize 50

int main() {
    key_t key = 5677;
    int shmid = shmget(key, SharedMemSize, IPC_CREAT | 0666);
    if (shmid < 0) { perror("shmget"); exit(1); }

    char *shared_memory = (char *)shmat(shmid, NULL, 0);
    if (shared_memory == (char *)-1) { perror("shmat"); exit(1); }

    sprintf(shared_memory, "Welcome to Shared Memory");
    printf("Data written to memory: %s\n", shared_memory);
    
    sleep(5); // Wait for receiver to read before exit
    shmdt(shared_memory);
    return 0;
}


