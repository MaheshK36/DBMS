Banker

#include <stdio.h>

int main() {
    int n, r, i, j, k;
    printf("Processes and Resource types: ");
    scanf("%d %d", &n, &r);
    int alloc[n][r], max[n][r], need[n][r], avail[r];
    int finish[n], safe_sequence[n], count = 0;

    printf("Enter Allocation Matrix:\n");
    for(i=0; i<n; i++) for(j=0; j<r; j++) scanf("%d", &alloc[i][j]);

    printf("Enter Max Matrix:\n");
    for(i=0; i<n; i++) for(j=0; j<r; j++) scanf("%d", &max[i][j]);

    printf("Enter Available Resources: ");
    for(i=0; i<r; i++) scanf("%d", &avail[i]);

    for(i=0; i<n; i++) {
        finish[i] = 0;
        for(j=0; j<r; j++) need[i][j] = max[i][j] - alloc[i][j];
    }

    while(count < n) {
        int found = 0;
        for(i=0; i<n; i++) {
            if(finish[i] == 0) {
                int possible = 1;
                for(j=0; j<r; j++) {
                    if(need[i][j] > avail[j]) {
                        possible = 0;
                        break;
                    }
                }
                if(possible) {
                    for(k=0; k<r; k++) avail[k] += alloc[i][k];
                    safe_sequence[count++] = i;
                    finish[i] = 1;
                    found = 1;
                }
            }
        }
        if(!found) {
            printf("System is in unsafe state!\n");
            return 0;
        }
    }

    printf("Safe sequence: ");
    for(i=0; i<n; i++) printf("P%d ", safe_sequence[i]);
    return 0;
}

Semaphore

#include <stdio.h>
#include <pthread.h>
#include <semaphore.h>
#include <unistd.h>

#define BUFFER_SIZE 5
int buffer[BUFFER_SIZE];
int in = 0, out = 0;
sem_t mutex, empty, full;

void* producer(void* arg) {
    for (int i = 0; i < 10; i++) {
        sem_wait(&empty);
        sem_wait(&mutex);
        buffer[in] = i;
        printf("Produced: %d\n", i);
        in = (in + 1) % BUFFER_SIZE;
        sem_post(&mutex);
        sem_post(&full);
        sleep(1);
    }
    return NULL;
}

void* consumer(void* arg) {
    for (int i = 0; i < 10; i++) {
        sem_wait(&full);
        sem_wait(&mutex);
        int item = buffer[out];
        printf("Consumed: %d\n", item);
        out = (out + 1) % BUFFER_SIZE;
        sem_post(&mutex);
        sem_post(&empty);
        sleep(2);
    }
    return NULL;
}

int main() {
    pthread_t p, c;
    sem_init(&mutex, 0, 1);
    sem_init(&empty, 0, BUFFER_SIZE);
    sem_init(&full, 0, 0);

    pthread_create(&p, NULL, producer, NULL);
    pthread_create(&c, NULL, consumer, NULL);

    pthread_join(p, NULL);
    pthread_join(c, NULL);

    sem_destroy(&mutex);
    sem_destroy(&empty);
    sem_destroy(&full);
    return 0;
}


First Fit

#include <stdio.h>

int main() {
    int m, n, i, j;
    printf("Enter number of memory blocks: ");
    scanf("%d", &m);
    int block[m], original[m];
    printf("Enter size of each block:\n");
    for(i = 0; i < m; i++) {
        scanf("%d", &block[i]);
        original[i] = block[i];
    }

    printf("Enter number of processes: ");
    scanf("%d", &n);
    int process[n];
    printf("Enter size of each process:\n");
    for(i = 0; i < n; i++) {
        scanf("%d", &process[i]);
    }

    for(i = 0; i < n; i++) {
        int found = 0;
        for(j = 0; j < m; j++) {
            if(block[j] >= process[i]) {
                int fragment = block[j] - process[i];
                printf("P%d (size %d) -> Block %d (size %d), Fragment: %d\n", 
                        i+1, process[i], j+1, original[j], fragment);
                block[j] -= process[i]; // Update remaining block size
                found = 1;
                break;
            }
        }
        if(!found) printf("P%d (size %d) could not be allocated\n", i+1, process[i]);
    }
    return 0;
}


