FCFS

#include <stdio.h>

int main() {
    int n, i;
    float totalTAT = 0, totalWT = 0;
    printf("Enter number of processes: ");
    scanf("%d", &n);
    int at[n], bt[n], ct[n], tat[n], wt[n];

    for(i = 0; i < n; i++) {
        printf("Enter Arrival Time and Burst Time for P%d: ", i + 1);
        scanf("%d %d", &at[i], &bt[i]);
    }

    // Calculate Completion Time
    ct[0] = at[0] + bt[0];
    for(i = 1; i < n; i++) {
        if(ct[i-1] < at[i])
            ct[i] = at[i] + bt[i];
        else
            ct[i] = ct[i-1] + bt[i];
    }

    for(i = 0; i < n; i++) {
        tat[i] = ct[i] - at[i];
        wt[i] = tat[i] - bt[i];
        totalTAT += tat[i];
        totalWT += wt[i];
    }

    printf("\nAverage Turnaround Time: %.2f", totalTAT/n);
    printf("\nAverage Waiting Time: %.2f\n", totalWT/n);
    return 0;
}


SJF

#include <stdio.h>

int main() {
    int n, i, j, time = 0, min, p;
    float avgTAT = 0, avgWT = 0;
    printf("Enter number of processes: ");
    scanf("%d", &n);
    int at[n], bt[n], ct[n], tat[n], wt[n], done[n];

    for(i = 0; i < n; i++) {
        printf("Enter Arrival Time and Burst Time for P%d: ", i + 1);
        scanf("%d %d", &at[i], &bt[i]);
        done[i] = 0;
    }

    for(i = 0; i < n; i++) {
        min = 999;
        p = -1;
        for(j = 0; j < n; j++) {
            if(at[j] <= time && done[j] == 0 && bt[j] < min) {
                min = bt[j];
                p = j;
            }
        }
        if(p == -1) {
            time++;
            i--; // Stay on the same iteration until a process is found
        } else {
            time += bt[p];
            ct[p] = time;
            done[p] = 1;
        }
    }

    for(i = 0; i < n; i++) {
        tat[i] = ct[i] - at[i];
        wt[i] = tat[i] - bt[i];
        avgTAT += tat[i];
        avgWT += wt[i];
    }
    printf("\nAverage Turnaround Time = %.2f\n", avgTAT/n);
    printf("Average Waiting Time = %.2f\n", avgWT/n);
    return 0;
}


Priority

#include <stdio.h>

int main() {
    int n, i, j, time = 0, completed = 0;
    float total_wt = 0, total_tat = 0;
    printf("Enter number of processes: ");
    scanf("%d", &n);
    int at[n], bt[n], pr[n], wt[n], tat[n], ct[n], done[n];

    for(i = 0; i < n; i++) {
        printf("Enter AT, BT and Priority for P%d: ", i + 1);
        scanf("%d %d %d", &at[i], &bt[i], &pr[i]);
        done[i] = 0;
    }

    while(completed < n) {
        int idx = -1;
        int highest_priority = 9999;
        for(i = 0; i < n; i++) {
            if(at[i] <= time && done[i] == 0) {
                if(pr[i] < highest_priority) {
                    highest_priority = pr[i];
                    idx = i;
                } else if(pr[i] == highest_priority) {
                    if(at[i] < at[idx]) idx = i; // FCFS as tie-breaker
                }
            }
        }

        if(idx != -1) {
            time += bt[idx];
            ct[idx] = time;
            tat[idx] = ct[idx] - at[idx];
            wt[idx] = tat[idx] - bt[idx];
            total_wt += wt[idx];
            total_tat += tat[idx];
            done[idx] = 1;
            completed++;
        } else {
            time++;
        }
    }

    printf("\nAverage Turnaround Time = %.2f", total_tat / n);
    printf("\nAverage Waiting Time = %.2f\n", total_wt / n);
    return 0;
}


Round Robin

#include <stdio.h>

int main() {
    int n, tq, i;
    printf("Enter number of processes: ");
    scanf("%d", &n);
    printf("Enter Time Quantum: ");
    scanf("%d", &tq);

    int at[n], bt[n], rt[n], ct[n], tat[n], wt[n];
    int completed = 0, time = 0;

    for(i = 0; i < n; i++) {
        printf("Enter AT and BT for P%d: ", i + 1);
        scanf("%d %d", &at[i], &bt[i]);
        rt[i] = bt[i]; // Remaining time starts as burst time
    }

    while(completed < n) {
        int executed = 0;
        for(i = 0; i < n; i++) {
            if(at[i] <= time && rt[i] > 0) {
                executed = 1;
                if(rt[i] > tq) {
                    time += tq;
                    rt[i] -= tq;
                } else {
                    time += rt[i];
                    rt[i] = 0;
                    ct[i] = time;
                    completed++;
                }
            }
        }
        if (executed == 0) time++; // Idle time if no process has arrived
    }

    float total_tat = 0, total_wt = 0;
    for(i = 0; i < n; i++) {
        tat[i] = ct[i] - at[i];
        wt[i] = tat[i] - bt[i];
        total_tat += tat[i];
        total_wt += wt[i];
    }

    printf("\nAverage Turnaround Time: %.2f", total_tat / n);
    printf("\nAverage Waiting Time: %.2f\n", total_wt / n);
    return 0;
}


