#include <stdio.h>

int main() {
    int m, n, i, j;
    printf("Enter number of blocks: ");
    scanf("%d", &m);
    int block[m], original[m];
    for(i = 0; i < m; i++) {
        scanf("%d", &block[i]);
        original[i] = block[i];
    }
    printf("Enter number of processes: ");
    scanf("%d", &n);
    int process[n];
    for(i = 0; i < n; i++) scanf("%d", &process[i]);

    for(i = 0; i < n; i++) {
        int bestIdx = -1;
        for(j = 0; j < m; j++) {
            if(block[j] >= process[i]) {
                if(bestIdx == -1 || block[j] < block[bestIdx]) {
                    bestIdx = j;
                }
            }
        }
        if(bestIdx != -1) {
            int fragment = block[bestIdx] - process[i];
            printf("P%d allocated to Block %d, Fragment: %d\n", i+1, bestIdx+1, fragment);
            block[bestIdx] -= process[i];
        } else {
            printf("P%d not allocated\n", i+1);
        }
    }
    return 0;
}


FIFO

#include <stdio.h>

int main() {
    int n, f, i, j;
    printf("Enter number of pages in reference string: ");
    scanf("%d", &n);
    int pages[n];
    
    printf("Enter the reference string: ");
    for(i = 0; i < n; i++) {
        scanf("%d", &pages[i]);
    }

    printf("Enter number of frames: ");
    scanf("%d", &f);
    int frame[f];
    int front = 0;
    int faults = 0, hits = 0;

    // Initialize frames with -1 (empty)
    for(i = 0; i < f; i++) {
        frame[i] = -1;
    }

    for(i = 0; i < n; i++) {
        int found = 0;
        // Check if page is already in a frame (Hit)
        for(j = 0; j < f; j++) {
            if(frame[j] == pages[i]) {
                found = 1;
                hits++;
                break;
            }
        }

        // Page Fault occurs
        if (found == 0) {
            frame[front] = pages[i];
            front = (front + 1) % f; // Move pointer in circular fashion
            faults++;
        }
    }

    printf("\nTotal Page Faults: %d", faults);
    printf("\nTotal Page Hits: %d\n", hits);
    return 0;
}

LRU

#include <stdio.h>

int main() {
    int n, f, i, j;
    printf("Number of pages: ");
    scanf("%d", &n);
    int pages[n];
    for(i = 0; i < n; i++) scanf("%d", &pages[i]);
    printf("Number of frames: ");
    scanf("%d", &f);

    int frame[f], time[f], faults = 0, hits = 0, counter = 0;
    for(i = 0; i < f; i++) frame[i] = -1;

    for(i = 0; i < n; i++) {
        int found = -1;
        for(j = 0; j < f; j++) {
            if(frame[j] == pages[i]) {
                found = j;
                hits++;
                time[j] = ++counter;
                break;
            }
        }
        if(found == -1) {
            int lru = 0;
            for(j = 1; j < f; j++) {
                if(frame[j] == -1) { // Empty frame found
                    lru = j;
                    break;
                }
                if(time[j] < time[lru]) lru = j;
            }
            frame[lru] = pages[i];
            time[lru] = ++counter;
            faults++;
        }
    }
    printf("\nTotal Faults: %d\nTotal Hits: %d", faults, hits);
    return 0;
}
